    {
      "parameters": {
        "jsCode": "// This tells n8n to process every single item (candidate) in the list\nreturn $input.all().map(item => {\n  try {\n    // We parse the AI output for each specific candidate\n    const parsedOutput = JSON.parse(item.json.output);\n    \n    // We return the new parsed data while keeping the original info (like Name/Email)\n    return {\n      json: {\n        ...item.json,\n        ...parsedOutput\n      }\n    };\n  } catch (error) {\n    // If the AI output isn't valid JSON, we return the item with an error message\n    return {\n      json: {\n        ...item.json,\n        error: \"AI output was not valid JSON\",\n        raw_output: item.json.output\n      }\n    };\n  }\n});"
      },
